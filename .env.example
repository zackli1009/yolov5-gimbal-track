# ============================================================
# .env — docker compose 环境变量
# 复制本文件：cp .env.example .env，然后修改下面的路径
# ============================================================

# YOLOv5 仓库本地路径（对应 config.py: YOLOV5_REPO_PATH）
YOLOV5_DIR=/home/zan/yolov5

# 模型权重文件路径（对应 config.py: MODEL_PT_PATH）
MODEL_PT=/home/zan/models/best2.pt

# 蜂鸣器脚本所在目录（对应 config.py: BEEP_SCRIPT_PATH 的父目录）
BEEP_DIR=/home/zan/scripts

# X11 显示（cv2.imshow 需要，保持默认 :0 即可）
DISPLAY=:0
